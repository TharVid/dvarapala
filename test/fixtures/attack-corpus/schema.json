{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DvarapalaAttackScenario",
  "type": "object",
  "required": ["id", "category", "description", "messages", "expected"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "category": {
      "type": "string",
      "enum": [
        "tool-poisoning",
        "line-jumping",
        "tool-mutation",
        "indirect-prompt-injection",
        "secrets-exfil",
        "destructive-actions",
        "excessive-agency"
      ]
    },
    "description": { "type": "string" },
    "source": { "type": "string", "description": "Origin (paper, advisory, garak probe id)" },
    "messages": {
      "type": "array",
      "description": "Sequence of MCP JSON-RPC messages to feed to the gateway",
      "items": { "type": "object" }
    },
    "expected": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": { "enum": ["deny", "redact", "require_approval", "allow"] },
        "rule": { "type": "string" },
        "rulepack": { "type": "string" }
      }
    }
  }
}
